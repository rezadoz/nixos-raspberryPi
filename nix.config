# /etc/nix/nix.conf
# Nix daemon configuration for Raspberry Pi (aarch64-linux) on Raspbian
# Apply changes with: sudo systemctl restart nix-daemon

# ─────────────────────────────────────────────
# SUBSTITUTERS / BINARY CACHES
# Speeds up installs by pulling pre-built binaries instead of compiling.
# ─────────────────────────────────────────────

substituters = https://cache.nixos.org https://nix-community.cachix.org
trusted-public-keys = cache.nixos.org-1:6NCHdD59X431o0gWypbMrAURkbJ16ZPMQFGspcDShjY= nix-community.cachix.org-1:mB9FSh9qf2dCimDSUo8Zy7bkq5CX+/rkCWyvRCYg3Bg=

# Fallback: build locally if cache misses
fallback = true


# ─────────────────────────────────────────────
# FLAKES & NEW CLI  (quality-of-life)
# Enables `nix develop`, `nix build`, `nix run`, etc.
# ─────────────────────────────────────────────

experimental-features = nix-command flakes


# ─────────────────────────────────────────────
# BUILD PERFORMANCE
# Tuned conservatively for RPi — bump max-jobs on RPi 4/5.
# ─────────────────────────────────────────────

# Number of parallel build jobs. "auto" uses all cores; use 2-4 on RPi to
# leave headroom for the OS.
max-jobs = 4

# Threads per build job.
cores = 3

# Keep build dependencies after a successful build so rebuilds are faster.
keep-outputs = true
keep-derivations = true

# How long (in seconds) to keep failed builds around for inspection.
# 0 = delete immediately; 3600 = keep for 1 hour.
# keep-failed = false   # uncomment to auto-delete failed build dirs


# ─────────────────────────────────────────────
# GARBAGE COLLECTION
# ─────────────────────────────────────────────

# Automatically run GC when free disk space drops below this threshold.
# Important on the typically small SD cards used with RPi.
min-free = 1073741824    # 1 GiB
max-free = 4294967296    # 4 GiB — stop collecting once this much is free

# Keep the last N generations of each profile before GC can collect them.
# (Set via `nix-env --delete-generations` or `nix profile wipe-history`.)


# ─────────────────────────────────────────────
# STORE & SANDBOXING
# ─────────────────────────────────────────────

# Sandboxed builds improve reproducibility.
# On Raspbian you may need to install `bubblewrap` first:
#   sudo apt install bubblewrap
sandbox = true

# If bubblewrap isn't available, fall back to relaxed mode:
# sandbox = relaxed

# Use a RAM-backed tmpfs for build directories (faster on SD card systems).
# Comment out if your RPi has <1 GB RAM.
build-dir = /tmp/nix-build


# ─────────────────────────────────────────────
# NETWORK
# ─────────────────────────────────────────────

# Number of parallel download connections.
http-connections = 25

# Timeout for stale file-transfer connections (seconds).
stalled-download-timeout = 90


# ─────────────────────────────────────────────
# LOGGING & UX
# ─────────────────────────────────────────────

# Show a progress bar during builds/fetches.
# (Only takes effect with the new CLI; nix-env always shows its own output.)
print-build-logs = true

# Log verbosity: 0=error 1=warn 2=notice(default) 3=info 4=talkative 5=chatty
# verbosity = 2


# ─────────────────────────────────────────────
# TRUSTED USERS
# Users in this list can override substituters and other restricted settings
# without sudo. Add your normal username here.
# ─────────────────────────────────────────────

trusted-users = root @wheel operator
allowed-users = *


# ─────────────────────────────────────────────
# NIXPKGS CONFIGURATION (global defaults)
# ─────────────────────────────────────────────

# Allow packages with non-free licenses (optional — comment out if unwanted).
# To enable per-user instead, set in ~/.config/nixpkgs/config.nix.
# nixpkgs-config = { allowUnfree = true; }

